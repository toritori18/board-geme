{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Read",
      "Glob",
      "Grep",
      "PowerShell(.\\.claude\\push.ps1 *)",
      "PowerShell(npm run *)",
      "PowerShell(git status)",
      "PowerShell(git log *)",
      "PowerShell(git diff *)",
      "PowerShell(git add *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if (-not (Test-Path .env.local)) { Copy-Item .env.example .env.local }",
            "shell": "powershell"
          }
        ]
      }
    ]
  }
}
